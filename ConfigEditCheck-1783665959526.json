              "payload": {
                "dataset": "AdminSQLCentral",
                "editorMode": "code",
                "format": "table",
                "rawQuery": true,
                "rawSql": "Insert into ITE_DBA_ADMIN_DB.dbo.MOMA_ConfigHistory\r\nSELECT [MetCat]\r\n      ,[Metric]\r\n      ,[Threshold]\r\n      ,[ThresholdValue]\r\n      ,[MomaAlert]\r\n\t  ,GetDATE(),'${__user.login}'\r\n  FROM ITE_DBA_ADMIN_DB.dbo.MOMA_Config;\r\n\r\nUPDATE ITE_DBA_ADMIN_DB.DBO.MOMA_Config\r\nSET \r\n  Threshold = '${payload.Threshold}',\r\n  MomaAlert = CASE \r\n                WHEN '${payload.MomaAlert}' = 'true' THEN 1 \r\n                WHEN '${payload.MomaAlert}' = 'false' THEN 0\r\n                WHEN '${payload.MomaAlert}' = '1' THEN 1\r\n                WHEN '${payload.MomaAlert}' = '0' THEN 0\r\n                ELSE 0 \r\n              END\r\nWHERE MetCat = '${payload.MetCat}';",
                "refId": "A",
                "sql": {
