          "dataset": "eTrackingUser",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_AEUWE1ER0247\\IO15}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "DECLARE @sql NVARCHAR(MAX) = '';\r\n\r\nSELECT @sql = @sql + '\r\nUSE [' + name + '];\r\n\r\nSELECT \r\n    ''' + name + ''' AS database_name,\r\n    MAX(STATS_DATE(i.object_id, i.index_id)) AS last_updated,\r\n    DATEDIFF(day, MAX(STATS_DATE(i.object_id, i.index_id)), GETDATE()) AS diff_days\r\nFROM sys.indexes i\r\nWHERE i.index_id > 0\r\n  AND STATS_DATE(i.object_id, i.index_id) IS NOT NULL;\r\n\r\n'\r\nFROM sys.databases\r\nWHERE state_desc = 'ONLINE'\r\n  AND database_id > 4;\r\n\r\nEXEC sp_executesql @sql;",
          "refId": "A",
