      "targets": [
        {
          "dataset": "AdminSQLCentral",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_CENTRAL}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "select * ,\r\nCASE \r\nWHEN SQLMajor=17  THEN 'SQL Server 2025' \r\nWHEN SQLMajor=16  THEN 'SQL Server 2022' \r\nWHEN SQLMajor=15  THEN 'SQL Server 2019' \r\nWHEN SQLMajor=14  THEN 'SQL Server 2017' \r\nWHEN SQLMajor=13  THEN 'SQL Server 2016' \r\nWHEN SQLMajor=12  THEN 'SQL Server 2014' \r\nWHEN SQLMajor=11  THEN 'SQL Server 2012' \r\nWHEN SQLMajor=10  THEN 'SQL Server 2008 R2' \r\nEND SQLVersionName \r\nFROM   AdminSQLCentral.Inventory.ServerList \r\nwhere \r\nSupportGroup  LIKE \r\n  CASE\r\n    WHEN $__user = 18 THEN 'DXC%'\r\n    ELSE '%' END and (\r\nServerName like '%$Search%'\r\nor Environment like '%$Search%'\r\nor ApplicationGroupName like '%$Search%' )\r\nORDER BY Environment,ApplicationGroupName,ServerName",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
