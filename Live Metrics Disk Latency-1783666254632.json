      "pluginVersion": "3.6.1",
      "targets": [
        {
          "alias": "",
          "datasource": {
            "type": "mssql",
            "uid": "${Datasource}"
          },
          "editorMode": "code",
          "format": "table",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "\r\n\r\nselect *,\r\n   '<p style=\"font-size: 11px;color: grey;\"><a href=\"/d/SQLServerDatabaseIO/sql-server-database-i-o?orgId=1?$__url_time_range&var-Datasource='+ a.ServerName+ '\">Database Latency</a></p>' DBLatency\r\nfrom\r\n(SELECT\r\n SERVERPROPERTY('MachineName') AS HostName,\r\n \tUPPER(CASE \r\n        WHEN len(isnull(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)),'')) = 0 THEN UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n        ELSE UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n             + '\\' + UPPER(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)))\r\n      END) As ServerName,\r\n    LEFT(mf.physical_name, 2) AS Drive,\r\n\r\n    COUNT(*) AS FileCount,\r\n\r\n    +'<p style=\"font-size: 11px;color: grey;\">'+ cast(SUM(vfs.num_of_reads) as varchar(20)) AS TotalReads,\r\n    +'<p style=\"font-size: 11px;color: grey;\">'+ cast(SUM(vfs.num_of_writes) as varchar(20))  AS TotalWrites,\r\n\r\n    cast(SUM(vfs.num_of_bytes_read) / 1048576 as bigint) AS MBRead,\r\n    cast(SUM(vfs.num_of_bytes_written) / 1048576 as bigint) AS MBWritten,\r\n\r\n    SUM(vfs.io_stall_read_ms) AS ReadStall_ms,\r\n    SUM(vfs.io_stall_write_ms) AS WriteStall_ms,\r\n    SUM(vfs.io_stall) AS TotalStall_ms,\r\n\r\n    CAST(CASE\r\n        WHEN SUM(vfs.num_of_reads) = 0 THEN 0\r\n        ELSE SUM(vfs.io_stall_read_ms) * 1.0 / SUM(vfs.num_of_reads)\r\n    END AS DECIMAL(18,2)) AS AvgReadLatency_ms,\r\n\r\n    CAST(CASE\r\n        WHEN SUM(vfs.num_of_writes) = 0 THEN 0\r\n        ELSE SUM(vfs.io_stall_write_ms) * 1.0 / SUM(vfs.num_of_writes)\r\n    END AS DECIMAL(18,2)) AS AvgWriteLatency_ms,\r\n\r\n    CAST(CASE\r\n        WHEN SUM(vfs.num_of_reads + vfs.num_of_writes) = 0 THEN 0\r\n        ELSE SUM(vfs.io_stall) * 1.0 /\r\n             SUM(vfs.num_of_reads + vfs.num_of_writes)\r\n    END AS DECIMAL(18,2)) AS AvgIOLatency_ms\r\n\r\nFROM sys.dm_io_virtual_file_stats(NULL, NULL) vfs\r\nJOIN sys.master_files mf\r\n    ON vfs.database_id = mf.database_id\r\n   AND vfs.file_id = mf.file_id\r\nGROUP BY LEFT(mf.physical_name, 2)\r\n) a\r\nORDER BY AvgIOLatency_ms DESC\r\n\r\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
