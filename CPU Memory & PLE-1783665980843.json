          "rawQuery": true,
          "rawSql": "SELECT \r\n    (SELECT COUNT(*) \r\n     FROM [Archive].[XMLDeadlockReport]\r\n     WHERE EventTimeStamp >= DATEADD(HOUR, -24, GETDATE())\r\n    ) AS NoOfDeadlocks,\r\n    (SELECT COUNT(*) \r\n     FROM [Archive].[BlockedProcessReport]\r\n     WHERE EventTimeStamp >= DATEADD(HOUR, -24, GETDATE())\r\n    ) AS NoOfBlockings;",
