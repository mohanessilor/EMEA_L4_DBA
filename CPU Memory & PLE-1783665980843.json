          "rawQuery": true,
          "rawSql": "SELECT \r\n[counter_name],\r\n[cntr_value] FROM sys.dm_os_performance_counters\r\nWHERE [object_name] LIKE '%Manager%'\r\nAND [counter_name] = 'Page life expectancy'",
          "refId": "ple",
