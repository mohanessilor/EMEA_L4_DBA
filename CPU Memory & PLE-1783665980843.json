              }
            ],
            "limit": 50
          }
        },
        {
          "dataset": "eTrackingUser",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_AEUWE1ER0247\\IO15}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\r\n SERVERPROPERTY('MachineName') AS ServerName,\r\n SERVERPROPERTY('InstanceName') AS InstanceName,\r\n SERVERPROPERTY('Edition') AS Edition,\r\n SERVERPROPERTY('ProductVersion') AS ProductVersion,\r\n SERVERPROPERTY('ProductLevel') AS ProductLevel,\r\n (SELECT 100 * CAST(total_physical_memory_kb/1024 AS DECIMAL(18))\r\nFROM sys.dm_os_sys_memory) OSMemory,\r\n   (SELECT [value] FROM sys.configurations WHERE name like '%min server memory%') AS min_server_memory,\r\n   (SELECT [value] FROM sys.configurations WHERE name like '%max server memory%') AS max_server_memory",
          "refId": "prty",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
