          "rawQuery": true,
          "rawSql": "\r\nSELECT \r\nCASE A.ServerName\r\nWHEN 'PLER0104\\PXRP' THEN 'EOLP'\r\nWHEN 'THER5004\\PRNW' THEN 'ELTL'\r\nWHEN 'AZSEAER0012\\PRT1' THEN 'SEDICO'\r\nWHEN 'CNER0343\\PXRH' THEN 'CHLOE'\r\nWHEN 'CNT-RXREPP01\\PXRT' THEN 'TRISTAR'\r\nWHEN 'INLR0425\\PXRG' THEN 'EMIL'\r\nEND AS 'LAB',*\r\nFROM \r\n(\r\nSELECT\r\n    UPPER(\r\n        CASE\r\n            WHEN LEN(ISNULL(CAST(SERVERPROPERTY('InstanceName') AS VARCHAR(20)), '')) = 0\r\n                THEN CAST(SERVERPROPERTY('MachineName') AS VARCHAR(20))\r\n            ELSE CAST(SERVERPROPERTY('MachineName') AS VARCHAR(20))\r\n                 + '\\' + CAST(SERVERPROPERTY('InstanceName') AS VARCHAR(20))\r\n        END\r\n    ) AS ServerName,\r\n\r\n    CASE publication_type\r\n        WHEN 0 THEN 'Transactional'\r\n        WHEN 1 THEN 'Snapshot'\r\n        WHEN 2 THEN 'Merge'\r\n    END AS publication_type,\r\n\r\n    CASE\r\n        WHEN MAX(CASE WHEN status IN (5,6) THEN 1 ELSE 0 END) = 1\r\n            THEN 'Error'\r\n        ELSE 'OK'\r\n    END AS [status]\r\n\r\nFROM distribution.dbo.MSreplication_monitordata  where publication_type=0\r\nGROUP BY\r\n    publication_type ) A",
