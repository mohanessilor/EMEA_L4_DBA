      "targets": [
        {
          "dataset": "ITE_DBA_ADMIN_DB",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_PLER0101\\PRNP}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "DECLARE @DBName sysname\r\nDECLARE @SQL nvarchar(max)\r\n\r\nIF DB_ID('ITE_DBA_ADMIN_DB') IS NOT NULL\r\n    SET @DBName = 'ITE_DBA_ADMIN_DB'\r\nELSE IF DB_ID('AdminSQL') IS NOT NULL\r\n    SET @DBName = 'AdminSQL'\r\nELSE\r\nBEGIN\r\n    RAISERROR('Neither ITE_DBA_ADMIN_DB nor AdminSQL database exists.',16,1)\r\n    RETURN\r\nEND\r\n\r\nSET @SQL = '\r\n;WITH Hours AS (\r\n    SELECT DATEADD(\r\n                HOUR,\r\n                -${Rhours},\r\n                DATEADD(\r\n                    HOUR,\r\n                    DATEDIFF(\r\n                        HOUR,\r\n                        0,\r\n                        CAST(\r\n                            SYSUTCDATETIME() AT TIME ZONE ''UTC''\r\n                                              AT TIME ZONE ''Romance Standard Time''\r\n                            AS datetime2\r\n                        )\r\n                    ),\r\n                    0\r\n                )\r\n           ) AS EventHour\r\n\r\n    UNION ALL\r\n\r\n    SELECT DATEADD(HOUR, 1, EventHour)\r\n    FROM Hours\r\n    WHERE EventHour <\r\n          DATEADD(\r\n              HOUR,\r\n              DATEDIFF(\r\n                  HOUR,\r\n                  0,\r\n                  CAST(\r\n                      SYSUTCDATETIME() AT TIME ZONE ''UTC''\r\n                                        AT TIME ZONE ''Romance Standard Time''\r\n                      AS datetime2\r\n                  )\r\n              ),\r\n              0\r\n          )\r\n),\r\n\r\nDeadlocks AS (\r\n    SELECT\r\n        DATEADD(\r\n            HOUR,\r\n            DATEDIFF(\r\n                HOUR,\r\n                0,\r\n                CAST(\r\n                    EventTimeStamp AT TIME ZONE ''UTC''\r\n                                   AT TIME ZONE ''Romance Standard Time''\r\n                    AS datetime2\r\n                )\r\n            ),\r\n            0\r\n        ) AS EventHour,\r\n        COUNT(*) AS DeadlockCount\r\n    FROM [' + @DBName + '].[Archive].[XMLDeadlockReport]\r\n    GROUP BY\r\n        DATEADD(\r\n            HOUR,\r\n            DATEDIFF(\r\n                HOUR,\r\n                0,\r\n                CAST(\r\n                    EventTimeStamp AT TIME ZONE ''UTC''\r\n                                   AT TIME ZONE ''Romance Standard Time''\r\n                    AS datetime2\r\n                )\r\n            ),\r\n            0\r\n        )\r\n),\r\n\r\nBlockings AS (\r\n    SELECT\r\n        DATEADD(\r\n            HOUR,\r\n            DATEDIFF(\r\n                HOUR,\r\n                0,\r\n                CAST(\r\n                    EventTimeStamp AT TIME ZONE ''UTC''\r\n                                   AT TIME ZONE ''Romance Standard Time''\r\n                    AS datetime2\r\n                )\r\n            ),\r\n            0\r\n        ) AS EventHour,\r\n        COUNT(*) AS BlockingCount\r\n    FROM [' + @DBName + '].[Archive].[BlockedProcessReport]\r\n    GROUP BY\r\n        DATEADD(\r\n            HOUR,\r\n            DATEDIFF(\r\n                HOUR,\r\n                0,\r\n                CAST(\r\n                    EventTimeStamp AT TIME ZONE ''UTC''\r\n                                   AT TIME ZONE ''Romance Standard Time''\r\n                    AS datetime2\r\n                )\r\n            ),\r\n            0\r\n        )\r\n)\r\n\r\nSELECT\r\n    CAST(H.EventHour AS DATE) AS EventDay,\r\n    RIGHT(''0'' + CAST(DATEPART(HOUR, H.EventHour) AS VARCHAR(2)),2) + '':00'' AS EventHour,\r\n    ISNULL(D.DeadlockCount,0) AS NoOfDeadlocks,\r\n    ISNULL(B.BlockingCount,0) AS NoOfBlockings\r\nFROM Hours H\r\nLEFT JOIN Deadlocks D\r\n    ON H.EventHour = D.EventHour\r\nLEFT JOIN Blockings B\r\n    ON H.EventHour = B.EventHour\r\nORDER BY H.EventHour DESC\r\nOPTION (MAXRECURSION ${Rhours});'\r\n\r\nEXEC sp_executesql @SQL;",
          "refId": "A",
          "sql": {
            "columns": [
