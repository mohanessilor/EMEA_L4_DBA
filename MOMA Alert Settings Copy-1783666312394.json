            "update": {
              "datasource": {
                "type": "mssql",
                "uid": "${Datasource}"
              },
              "payload": {
                "dataset": "EVENTDB",
                "editorMode": "code",
                "format": "table",
                "rawQuery": true,
                "rawSql": "INSERT INTO moma.MOMA_ConfigHistory\r\n(\r\n    [MetCat],\r\n    [Metric],\r\n    [Threshold],\r\n    [ThresholdValue],\r\n    [MomaAlert],\r\n    [Frequency],\r\n    [LastUpdatedTime],\r\n    [LastUpdatedby]\r\n\r\n)\r\nSELECT \r\n    c.[MetCat],\r\n    c.[Metric],\r\n    c.[Threshold],\r\n    c.[ThresholdValue],\r\n    c.[MomaAlert],\r\n    c.[Frequency],\r\n    GETDATE(),\r\n    '${__user.login}'\r\nFROM moma.MOMA_Config c\r\nOUTER APPLY\r\n(\r\n    SELECT TOP 1 *\r\n    FROM moma.MOMA_ConfigHistory h\r\n    WHERE h.MetCat = c.MetCat\r\n      AND h.Metric = c.Metric\r\n    ORDER BY h.LastUpdatedTime DESC\r\n) h\r\nWHERE \r\n    h.MetCat IS NULL\r\n    OR (\r\n        h.Threshold <> c.Threshold\r\n        OR h.ThresholdValue <> c.ThresholdValue\r\n        OR h.MomaAlert <> c.MomaAlert \r\n        OR h.Frequency <> c.Frequency\r\n    );\r\n\r\n\r\nUPDATE moma.MOMA_Config\r\nSET \r\n  Threshold = '${payload.Threshold}',\r\n    Frequency = '${payload.Frequency}' ,\r\n  MomaAlert = CASE \r\n                WHEN '${payload.MomaAlert}' = 'true' THEN 1 \r\n                WHEN '${payload.MomaAlert}' = 'false' THEN 0\r\n                WHEN '${payload.MomaAlert}' = '1' THEN 1\r\n                WHEN '${payload.MomaAlert}' = '0' THEN 0\r\n                ELSE 0 \r\n              END\r\nWHERE MetCat = '${payload.MetCat}';",
                "refId": "A",
                "sql": {
                  "columns": [
                    {
                      "parameters": [],
                      "type": "function"
                    }
                  ],
                  "groupBy": [
                    {
                      "property": {
                        "type": "string"
                      },
                      "type": "groupBy"
                    }
                  ],
                  "limit": 50
                }
              }
            }
