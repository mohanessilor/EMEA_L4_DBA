      "targets": [
        {
          "alias": "",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_PLER0104\\PXRP}"
          },
          "editorMode": "code",
          "format": "table",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "IF DB_ID('distribution') IS NOT NULL\r\nBEGIN\r\n    SELECT \r\n        SERVERPROPERTY('MachineName') AS ServerName,\r\n        SERVERPROPERTY('InstanceName') AS InstanceName,\r\n        a.publication,\r\n        a.publisher_db,\r\n        a.subscriber_db,\r\n\r\n        -- Latency in seconds since latest transaction entered distribution\r\n        CAST(DATEDIFF(SECOND, MAX(t.entry_time), GETDATE()) AS varchar(10)) AS Latency,\r\n\r\n        -- Undistributed commands pending for subscriber\r\n        ISNULL(MAX(s.UndelivCmdsInDistDB),0) AS UndistributedCommands\r\n\r\n    FROM distribution.dbo.MSrepl_transactions t\r\n    JOIN distribution.dbo.MSdistribution_agents a\r\n        ON t.publisher_database_id = a.publisher_database_id\r\n\r\n    LEFT JOIN distribution.dbo.MSdistribution_status s\r\n        ON a.id = s.agent_id\r\n\r\n    GROUP BY\r\n        a.publication,\r\n        a.publisher_db,\r\n        a.subscriber_db\r\nEND",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
