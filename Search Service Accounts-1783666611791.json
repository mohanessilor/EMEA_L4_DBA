          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT [Server_Name]\r\n      ,[Server_Services]\r\n      ,[Service_Account]\r\n      ,[Domain_Name] as Account_Type\r\n  FROM [AdminSQLCentral].[dbo].[DBA_SA_ALERTS] where \r\n    Service_Account like '%$Search%' \r\n  or SERVER_NAME like '%$Search%' \r\n  order by Service_Account",
