          "targets": [
            {
              "dataset": "eTrackingUser",
              "datasource": {
                "type": "mssql",
                "uid": "${DS_AEUWE1ER0642\\PO1B}"
              },
              "editorMode": "code",
              "format": "table",
              "rawQuery": true,
              "rawSql": "SELECT \r\nM.DatabaseName,\r\nM.FileType,\r\nM.MaxSize,\r\nM.UsedSize,\r\nM.TotalSize,\r\ncast(((M.MaxSize-M.UsedSize)/m.MaxSize*100) as decimal(18,2)) FreePer\r\nFROM \r\n\t(SELECT \r\n\tb.DatabaseName,\r\n\tb.FileGroup,\r\n\tb.FileType,\r\n\tcast(b.TotalSizePage as decimal(18,2))/128 TotalSize,\r\n\tcast(b.UsedSizePage as decimal(18,2))/128  UsedSize,\r\n\tcast(b.FreeSizePage as decimal(18,2))/128  FreeSize,\r\n\tcase  \r\n\twhen  b.MaxSizePage <0 then cast(a.Space_Free_Bytes as decimal(18,2))/1024\r\n\telse cast(b.MaxSizePage as decimal(18,2))/128 end MaxSize\r\n\tFROM [Archive].[DatabaseSize] b WITH (NOLOCK) \r\n\tINNER JOIN \r\n\t(\r\n\t\tSELECT DISTINCT\r\n\t\t\tvolume_mount_point AS [Disk_Mount_Point],\r\n\t\t\tCAST(available_bytes  AS BIGINT) AS  [Space_Free_Bytes],\r\n\t\t\tDB_NAME(sys.master_files.database_id) AS dbname,\r\n\t\t\ttype_desc\r\n\t\tFROM sys.master_files\r\n\t\tCROSS APPLY sys.dm_os_volume_stats(database_id, file_id)\r\n\t) a \r\n\tON a.dbname COLLATE DATABASE_DEFAULT = b.DatabaseName COLLATE DATABASE_DEFAULT\r\n\tAND a.type_desc COLLATE DATABASE_DEFAULT = b.FileType COLLATE DATABASE_DEFAULT\r\n\tWHERE  \r\n\tCAST(CheckDateTime AS DATE) = CAST(GETDATE() AS DATE) \r\n\t) M",
              "refId": "A",
              "sql": {
