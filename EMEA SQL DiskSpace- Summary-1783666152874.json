          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT\r\nDisk_Mount_Point,\r\nTotal_Size_in_GB, ---1GB = 1073741824 bytes,\r\nAvailable_Size_in_GB,\r\nSpace_Free_Per\r\nFROM \r\n(SELECT DISTINCT\r\nvolume_mount_point [Disk_Mount_Point] ,\r\nCAST(CONVERT(DECIMAL(18,2),total_bytes/1073741824.0) AS VARCHAR(10))  AS [Total_Size_in_GB], \r\nCAST(CONVERT(DECIMAL(18,2),available_bytes/1073741824.0) AS VARCHAR(10)) AS [Available_Size_in_GB],\r\nCAST(CAST(CAST(available_bytes AS FLOAT)/ CAST(total_bytes AS FLOAT) AS DECIMAL(18,2)) * 100  AS DECIMAL(10,2)) AS [Space_Free_Per]\r\nFROM sys.master_files\r\nCROSS APPLY sys.dm_os_volume_stats(database_id, file_id)) A",
