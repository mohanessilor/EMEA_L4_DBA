      "targets": [
        {
          "alias": "",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_CASD}"
          },
          "format": "time_series",
          "rawSql": "SELECT COALESCE(DATEADD(MONTH, DATEDIFF(MONTH, 0, OpenDate), 0), (DATEADD(MONTH, DATEDIFF(MONTH, 0, CloseDate), 0))) AS time\r\n\t,OpenCount\r\n\t,CloseCount\r\n\t,SUM(OpenCount) OVER (\r\n\t\tORDER BY OpenDate ROWS BETWEEN UNBOUNDED PRECEDING\r\n\t\t\t\tAND CURRENT ROW\r\n\t\t) - SUM(CloseCount) OVER (\r\n\t\tORDER BY CloseDate ROWS BETWEEN UNBOUNDED PRECEDING\r\n\t\t\t\tAND CURRENT ROW ) AS BackLog\r\nFROM (\r\n\tSELECT DATEADD(MONTH, DATEDIFF(MONTH, 0, open_date), 0) AS OpenDate\r\n\t\t,COUNT(*) AS OpenCount\r\n\tFROM [ESSTH].[dbo].[ChangeOrders]\r\n\tWHERE 1 = 1\r\n\t\tAND [group] IN ($Group)\r\n\t\tAND status <> 'Cancelled'\r\n\tGROUP BY DATEADD(MONTH, DATEDIFF(MONTH, 0, open_date), 0)\r\n\t) O\r\nFULL OUTER JOIN (\r\n\tSELECT DATEADD(MONTH, DATEDIFF(MONTH, 0, close_date), 0) AS CloseDate\r\n\t\t,COUNT(*) AS CloseCount\r\n\tFROM [ESSTH].[dbo].[ChangeOrders]\r\n\tWHERE 1 = 1\r\n\t\tAND [group] IN ($Group)\r\n\t\tAND status <> 'Cancelled'\r\n\tGROUP BY DATEADD(MONTH, DATEDIFF(MONTH, 0, close_date), 0)\r\n\t) C ON O.OpenDate = C.CloseDate\r\nWHERE COALESCE(OpenDate, CloseDate) IS NOT NULL\r\nORDER BY time ASC",
          "refId": "A"
        }
      ],
      "title": "Change Order Backlog",
      "type": "timeseries"
