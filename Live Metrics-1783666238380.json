      "targets": [
        {
          "alias": "",
          "datasource": {
            "type": "mssql",
            "uid": "${Datasource}"
          },
          "editorMode": "code",
          "format": "table",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "\r\nWITH CPU AS\r\n(\r\n    SELECT TOP (1)\r\n        record.value('(./Record/SchedulerMonitorEvent/SystemHealth/ProcessUtilization)[1]', 'int') AS SQL_CPU_Percent\r\n    FROM\r\n    (\r\n        SELECT CONVERT(XML, record) AS record\r\n        FROM sys.dm_os_ring_buffers\r\n        WHERE ring_buffer_type = N'RING_BUFFER_SCHEDULER_MONITOR'\r\n    ) x\r\n    ORDER BY record.value('(./Record/@id)[1]', 'int') DESC\r\n)\r\nselect *,\r\n   '<p style=\"font-size: 11px;color: blue;\"><a href=\"/d/afqrhky38hpmob/live-metrics-disk-latency?orgId=1?$__url_time_range&var-Datasource='+ a.ServerName+ '\">Disk Latency</a></p>' DiskLatency\r\n\r\nfrom (SELECT \r\n SERVERPROPERTY('MachineName') AS HostName,\r\n \tUPPER(CASE \r\n        WHEN len(isnull(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)),'')) = 0 THEN UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n        ELSE UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n             + '\\' + UPPER(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)))\r\n      END) As ServerName,\r\n SERVERPROPERTY('InstanceName') AS InstanceName,\r\n SERVERPROPERTY('Edition') AS Edition,\r\n SERVERPROPERTY('ProductVersion') AS ProductVersion,\r\n SERVERPROPERTY('ProductLevel') AS ProductLevel,\r\n (SELECT \r\n[cntr_value] FROM sys.dm_os_performance_counters\r\nWHERE [object_name] LIKE '%Manager%'\r\nAND [counter_name] = 'Page life expectancy' )  as PLE,\r\n   (SELECT SQL_CPU_Percent FROM CPU) as CPU_InUse,\r\n    (Select \r\n\tcast(100 *\r\n(SELECT 100* CAST(physical_memory_in_use_kb/1024 AS DECIMAL(18,2))\r\nFROM sys.dm_os_process_memory)\r\n/\r\n(SELECT 100 * CAST(total_physical_memory_kb/1024 AS DECIMAL(18,2))\r\nFROM sys.dm_os_sys_memory)\r\nas decimal(18,2))) as Mem_InUse,\r\n(SELECT\r\n    '<p style=\"font-size: 11px;color: grey;\">'+\r\n    cast(CAST(cast(cfg.value_in_use as numeric(18,2)) / 1024.0 AS DECIMAL(10,0)) as varchar(10))+ ' GB (' \r\n    +cast(CAST(os.total_physical_memory_kb / 1024.0 / 1024.0 AS DECIMAL(10,0)) as varchar(10))+ ' GB), '  as Text\r\nFROM sys.dm_os_sys_memory AS os \r\nCROSS JOIN (\r\n    SELECT value_in_use\r\n    FROM sys.configurations\r\n    WHERE name = 'max server memory (MB)'\r\n) AS cfg)+ \r\n concat(cast((SELECT [value] FROM sys.configurations WHERE name like '%max degree of parallelism%') as varchar(10)) ,' / '+\r\n   cast((SELECT [value] FROM sys.configurations WHERE name like '%cost threshold for parallelism%') as varchar(10)))+'</p>'  as ConfigText) a",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        },
        {
          "dataset": "AdminSQLCentral",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_CENTRAL}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT UPPER(ServerName) ServerName\r\n      ,ApplicationGroupName\r\n      ,Environment\r\n  FROM [AdminSQLCentral].[Inventory].[ServerList] WHERE ApplicationGroupName IN (${ApplicationGroupName})\r\nand Environment in (${Environment}) and Instance in (${Datasource})",
          "refId": "B",
          "sql": {
            "columns": [
