      "targets": [
        {
          "dataset": "FLEXNET",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_AEUWE1ER0211\\IBZ1}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT  \r\n    j.name AS job_name,\r\n    case when ISNULL(j.enabled,0)=0 then 0 else 1 end AS  Enabled,\r\n    case when ISNULL(sjs.schedule_id,0)=0 then 'No' else 'Yes' end AS schedule_enabled,\r\n    sch.name AS schedule_name,\r\n\r\n    -- Schedule frequency description\r\n    CASE sch.freq_type\r\n        WHEN 1 THEN 'One Time'\r\n        WHEN 4 THEN 'Daily'\r\n        WHEN 8 THEN 'Weekly'\r\n        WHEN 16 THEN 'Monthly'\r\n        WHEN 32 THEN 'Monthly (Relative)'\r\n        WHEN 64 THEN 'When SQL Agent Starts'\r\n        WHEN 128 THEN 'When CPU Idle'\r\n    END AS schedule_type,\r\n\r\n    js.step_name,\r\n    js.command\r\n\r\nFROM msdb.dbo.sysjobs j\r\nLEFT JOIN msdb.dbo.sysjobsteps js \r\n       ON j.job_id = js.job_id\r\nLEFT JOIN msdb.dbo.sysjobschedules sjs \r\n       ON j.job_id = sjs.job_id\r\nLEFT JOIN msdb.dbo.sysschedules sch \r\n       ON sjs.schedule_id = sch.schedule_id\r\n\r\nWHERE j.name LIKE '%' + ${JN:sqlstring} + '%'\r\n   OR js.step_name LIKE '%' + ${JN:sqlstring} + '%'\r\n   OR js.command LIKE '%' + ${JN:sqlstring} + '%'\r\nORDER BY j.name, js.step_id;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
