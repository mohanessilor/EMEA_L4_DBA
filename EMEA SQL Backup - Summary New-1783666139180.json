      "targets": [
        {
          "alias": "",
          "datasource": {
            "type": "mssql",
            "uid": "${Datasource}"
          },
          "editorMode": "code",
          "format": "table",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "SELECT\r\nUPPER(CASE \r\n        WHEN len(isnull(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)),'')) = 0 THEN UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n        ELSE UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n             + '\\' + UPPER(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)))\r\n      END) As ServerName,\r\n    DB.name AS DatabaseName,\r\n\r\n    CASE\r\n        WHEN DB.database_id <= 4 THEN 'System'\r\n        ELSE 'User'\r\n    END AS DatabaseType,\r\n\r\n    DB.recovery_model_desc AS Recovery_Model,\r\n\r\n    -- Last Backup Dates\r\n    MAX(CASE WHEN BS.type = 'D' THEN BS.backup_start_date END) AS LastFullBackup,\r\n    MAX(CASE WHEN BS.type = 'I' THEN BS.backup_start_date END) AS LastDiffBackup,\r\n    MAX(CASE WHEN BS.type = 'L' THEN BS.backup_start_date END) AS LastLogBackup,\r\n\r\n    -- Age of Backups (Days)\r\n    DATEDIFF(DAY,\r\n        MAX(CASE WHEN BS.type = 'D' THEN BS.backup_start_date END),\r\n        GETDATE()) AS FullBackupAge_Days,\r\n\r\n    DATEDIFF(DAY,\r\n        MAX(CASE WHEN BS.type = 'I' THEN BS.backup_start_date END),\r\n        GETDATE()) AS DiffBackupAge_Days,\r\n\r\n    DATEDIFF(DAY,\r\n        MAX(CASE WHEN BS.type = 'L' THEN BS.backup_start_date END),\r\n        GETDATE()) AS LogBackupAge_Days\r\n\r\nFROM sys.databases AS DB\r\nLEFT JOIN msdb.dbo.backupset AS BS\r\n    ON BS.database_name = DB.name\r\nLEFT JOIN msdb.dbo.backupmediafamily AS BMF\r\n    ON BS.media_set_id = BMF.media_set_id\r\nWHERE ISNULL(BS.is_damaged, 0) = 0\r\n--AND BMF.physical_device_name LIKE 'VNBU%'\r\nGROUP BY\r\n    DB.name,\r\n    DB.database_id,\r\n    DB.recovery_model_desc\r\nORDER BY\r\n    DatabaseType,\r\n    DatabaseName;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        },
        {
          "dataset": "AdminSQLCentral",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_CENTRAL}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT UPPER(ServerName) ServerName\r\n      ,ApplicationGroupName\r\n      ,Environment\r\n  FROM [AdminSQLCentral].[Inventory].[ServerList] WHERE ApplicationGroupName IN (${ApplicationGroupName})\r\nand Environment in (${Environment}) and Instance in (${Datasource})",
          "refId": "B",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
