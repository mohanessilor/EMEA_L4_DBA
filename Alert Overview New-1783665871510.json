          "editorMode": "code",
          "format": "table",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "\r\n\r\nSelect * ,\r\n'<head> <base target=\"_blank\"></head><p style=\"font-size: 11px;color: rgb(0, 128, 0);\"><a href=\"/d/AlertDetail/alert-detail?$__url_time_range&&var-Datasource='+Rf.ServerName +'\" target=\"_blank\"> Alert Detail </a>&nbsp;&nbsp; ' +\r\n'<a href=\"/d/IndexUsage/index-usage?$__url_time_range&var-Datasource='+Rf.ServerName +'\" target=\"_blank\"> Index Usage </a>&nbsp;&nbsp; ' +\r\n'<a href=\"/d/GrowthTrend/growth-trend?$__url_time_range&var-Datasource='+Rf.ServerName +'\" target=\"_blank\"> Growth Trend </a>&nbsp;&nbsp;<br> ' +\r\n'<a href=\"/d/Permissions/permissions?$__url_time_range&var-Datasource='+Rf.ServerName +'\" target=\"_blank\"> Permissions </a>&nbsp;&nbsp;' +\r\n'<a href=\"/d/SQLServerDatabaseCPU/sql-server-database-cpu?$__url_time_range&var-Datasource='+Rf.ServerName +'\"  target=\"_blank\"> SQL Server CPU By Database </a>&nbsp;&nbsp;' +\r\n'<a href=\"/d/SQLServerDatabaseIO/sql-server-database-i-o?$__url_time_range&var-Datasource='+Rf.ServerName +'\"  target=\"_blank\"> SQL Server IO By Database </a> &nbsp;&nbsp;<br>' +\r\n'<a href=\"/d/SQLServerOverview/sql-server-overview?$__url_time_range&var-Datasource='+Rf.ServerName +'\"  target=\"_blank\"> SQL Server Overview </a>&nbsp;&nbsp; ' +\r\n'<a href=\"/d/SQLServerConnections/sql-server-connections?$__url_time_range&var-Datasource='+Rf.ServerName +'\"  target=\"_blank\"> SQL Server Connections </a></p>'  RefLink\r\nFROM\r\n(SELECT \r\nUPPER(CASE \r\n        WHEN len(isnull(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)),'')) = 0 THEN UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n        ELSE UPPER(CAST(SERVERPROPERTY('MachineName') AS varchar(20)))\r\n             + '\\' + UPPER(CAST(SERVERPROPERTY('InstanceName') AS varchar(20)))\r\n      END) As ServerName,\r\n\t\t\tS.Severity\r\n\t , ISNULL([Count], 0) AS [Count]\r\n\t from\r\n(\r\n\tSELECT Severity\r\n\t\t , COUNT(DISTINCT name) AS [Count]\r\n\tFROM Monitoring.Alert\r\n\tWHERE $__timeFilter(CreateDateTime)\r\n\tGROUP BY Severity\r\n) AS A\r\nRIGHT JOIN Report.V_Severity AS S ON A.Severity = S.Severity ) Rf\r\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        },
        {
          "dataset": "AdminSQLCentral",
