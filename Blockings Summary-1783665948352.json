          "format": "table",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "DECLARE @DBName sysname\r\nDECLARE @SQL nvarchar(max)\r\n\r\n-- Detect which DBA database exists\r\nIF DB_ID('ITE_DBA_ADMIN_DB') IS NOT NULL\r\n    SET @DBName = 'ITE_DBA_ADMIN_DB'\r\nELSE IF DB_ID('AdminSQL') IS NOT NULL\r\n    SET @DBName = 'AdminSQL'\r\nELSE\r\nBEGIN\r\n    RAISERROR('Neither ITE_DBA_ADMIN_DB nor AdminSQL database exists.',16,1)\r\n    RETURN\r\nEND\r\n\r\n-- Build dynamic query\r\nSET @SQL = '\r\nSELECT \r\n      [SQLText],\r\n      [LoginName],\r\n      [SourceDatabase],\r\n      [Command],\r\n      [Application],\r\n      [HostName],\r\n      COUNT(*) AS NoOfBlockings\r\nFROM [' + @DBName + '].[Monitoring].[Blocking]\r\nWHERE DATEDIFF(HOUR, CheckDateTime, GETDATE()) < 24\r\n  AND BlockingTree NOT LIKE ''%-%''\r\nGROUP BY \r\n      [SQLText],\r\n      [LoginName],\r\n      [SourceDatabase],\r\n      [Command],\r\n      [Application],\r\n      [HostName]\r\nORDER BY COUNT(*) DESC;'\r\n\r\nEXEC sp_executesql @SQL\r\n",
          "refId": "A",
