      "targets": [
        {
          "alias": "",
          "datasource": {
            "type": "mssql",
            "uid": "${DS_AEUWE1ER0211\\IBZ1}"
          },
          "format": "time_series",
          "rawSql": ";WITH DatabaseIOThroughput AS\r\n(\r\n    SELECT DENSE_RANK() OVER (\r\n            ORDER BY CheckDateTime ASC\r\n            ) AS ID,\r\n\t\t    CheckDateTime,\r\n        DatabaseName,\r\n        SUM(num_of_bytes_read) AS num_of_bytes_read,\r\n\t\tSUM(num_of_bytes_written) AS num_of_bytes_written\r\n    FROM [Archive].[FileStatistics]\r\n    WHERE 1=1\r\n    AND $__timeFilter(CheckDateTime)\r\n    GROUP BY CheckDateTime, DatabaseName\r\n)\r\nSELECT  a.CheckDateTime AS time,\r\n\t      a.DatabaseName,\r\n        (a.num_of_bytes_read - aPrior.num_of_bytes_read)/1024/1024*1.0/DATEDIFF(ss, aPrior.CheckDateTime, a.CheckDateTime) AS ReadThroughputMBPS,\r\n        (a.num_of_bytes_written - aPrior.num_of_bytes_written)/1024/1024*1.0/DATEDIFF(ss, aPrior.CheckDateTime, a.CheckDateTime) AS WriteThroughputMBPS\r\nFROM DatabaseIOThroughput a\r\nINNER JOIN DatabaseIOThroughput aPrior\r\nON a.DatabaseName = aPrior.DatabaseName\r\nAND a.ID - 1 = aPrior.ID\r\nWHERE a.num_of_bytes_read >= aPrior.num_of_bytes_read\r\nAND a.num_of_bytes_written >= aPrior.num_of_bytes_written\r\nORDER BY time ASC",
          "refId": "A"
        }
      ],
      "title": "Bytes R/W",
      "type": "timeseries"
